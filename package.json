{
  "name": "crow-animation-ready",
  "version": "1.0.0",
  "private": true,
  "description": "Deploy-ready optimized static package for scroll-driven crow animation.",
  "scripts": {
    "serve": "npx serve . -l 8080",
    "serve:python": "python3 -m http.server 8080",
    "check:js": "node --check script.js",
    "lighthouse": "mkdir -p reports && lighthouse http://127.0.0.1:8080 --chrome-flags=\"--headless --no-sandbox\" --config-path=./lighthouse.config.cjs --output=html --output=json --output-path=./reports/lighthouse-report"
  },
  "devDependencies": {
    "@lhci/cli": "latest",
    "lighthouse": "latest",
    "serve": "latest"
  }
}
